getLabelSize(size) =>
    size == "Tiny" ? size.tiny :
         size == "Small" ? size.small :
         size == "Large" ? size.large :
         size.normal

getTablePosition(pos) =>
    pos == "Bottom Right" ? position.bottom_right : pos == "Top Right" ? position.top_right : pos == "Bottom Left" ? position.bottom_left : pos == "Bottom Center" ? position.bottom_center : pos == "Top Left" ? position.top_left : position.top_center

formatDateFromTime(int t) =>
    mon = month(t)
    day = dayofmonth(t)
    str.format("{0}/{1}", mon < 10 ? "0" + str.tostring(mon) : str.tostring(mon), day < 10 ? "0" + str.tostring(day) : str.tostring(day))

