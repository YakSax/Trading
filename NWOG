// ==================== STRICT WICK-GAP + VOLUME IMBALANCE FVG DETECTION ====================
detectFvg() =>
    float minGap = minFvgSize * syminfo.mintick
    bool bullGap = low > high[2] and (low - high[2]) >= minGap
    bool bearGap = high < low[2] and (low[2] - high) >= minGap
    float fvgTop = na
    float fvgBot = na
    bool isBull = false

    if bullGap
        fvgTop := low
        fvgBot := high[2]
        float body2Top = math.max(close[2], open[2])
        float body1Bot = math.min(close[1], open[1])
        float body1Top = math.max(close[1], open[1])
        float body0Bot = math.min(close, open)
        if body2Top < body1Bot
            fvgBot := body2Top
        if body1Top < body0Bot
            fvgTop := body0Bot
        isBull := true
    else if bearGap
        fvgTop := low[2]
        fvgBot := high
        float body2Bot = math.min(close[2], open[2])
        float body1Top = math.max(close[1], open[1])
        float body1Bot = math.min(close[1], open[1])
        float body0Top = math.max(close, open)
        if body2Bot > body1Top
            fvgTop := body2Bot
        if body1Bot > body0Top
            fvgBot := body0Top
        isBull := false

    [bullGap or bearGap, isBull, fvgTop, fvgBot]

