// PURE FVG detection (no globals modified)
detectFVG() =>
    bool bull = low > high[2] and close[1] > high[2]
    bool bear = high < low[2] and close[1] < low[2]
    [bull, bear]

// helper: test vertical overlap/touch between two intervals [bBottom, bTop] and [fBottom, fTop]
// Returns true if ANY FVG (of the selected polarity) overlaps or touches the breaker vertical span.
fvgSharesVerticalBoundary(float bTop, float bBottom, bool checkBull) =>
    bool found = false
    if checkBull
        if array.size(bullFVGArray) > 0
            for i = 0 to array.size(bullFVGArray) - 1
                f = array.get(bullFVGArray, i)
                if not na(f.top) and not na(f.bottom)
                    // overlap or touch: f.top >= bBottom && f.bottom <= bTop
                    if f.top >= bBottom and f.bottom <= bTop
                        found := true
                        break
    else
        if array.size(bearFVGArray) > 0
            for i = 0 to array.size(bearFVGArray) - 1
                f = array.get(bearFVGArray, i)
                if not na(f.top) and not na(f.bottom)
                    if f.top >= bBottom and f.bottom <= bTop
                        found := true
                        break
    found

// checkFVG: create/display FVG boxes/lines and remove them on mitigation
// NEW: Enforce only `showLastFVG` newest entries have visible box/midLine; older visuals are removed.
checkFVG() =>
    float bullBreak = mitigation == "Close" ? close : low
    float bearBreak = mitigation == "Close" ? close : high

    // bullish FVGs (display/update/remove)
    totalB = array.size(bullFVGArray)
    if totalB > 0
        disp = 0
        // iterate newest -> oldest
        for i = totalB - 1 to 0
            bullTestFVG = array.get(bullFVGArray, i)
            // if this index is within newest showLastFVG, create/update visuals
            if disp < showLastFVG
                // ensure visuals exist (create if na)
                if na(bullTestFVG.fvgBox)
                    bullTestFVG.fvgBox := box.new(top = bullTestFVG.top, bottom = bullTestFVG.bottom, left = bullTestFVG.left, right = time, xloc = bullTestFVG.xlocFVG, bgcolor = upFVGColor, border_width = 0)
                    bullTestFVG.midLine := line.new(x1 = bullTestFVG.left, y1 = (bullTestFVG.top + bullTestFVG.bottom)/2, x2 = time, y2 = (bullTestFVG.top + bullTestFVG.bottom)/2, xloc = bullTestFVG.xlocFVG, color = color.new(color.white, 75), style = line.style_dashed)
                else
                    // extend visuals
                    bullTestFVG.midLine.set_x2(time + (time - time[1]) * extendFVG)
                    bullTestFVG.fvgBox.set_right(time + (time - time[1]) * extendFVG)
                disp += 1
            else
                // older than shown limit — ensure visuals do not exist
                if not na(bullTestFVG.fvgBox)
                    bullTestFVG.fvgBox.delete()
                    bullTestFVG.fvgBox := na
                if not na(bullTestFVG.midLine)
                    bullTestFVG.midLine.delete()
                    bullTestFVG.midLine := na

            // mitigation: if break occurs remove visuals and array entry
            if bullBreak < bullTestFVG.bottom
                if not na(bullTestFVG.fvgBox)
                    bullTestFVG.fvgBox.delete()
                if not na(bullTestFVG.midLine)
                    bullTestFVG.midLine.delete()
                array.remove(bullFVGArray, i)
                // adjust counters after removal
                totalB := array.size(bullFVGArray)
                

    // bearish FVGs (display/update/remove)
    totalR = array.size(bearFVGArray)
    if totalR > 0
        dispR = 0
        for i = totalR - 1 to 0
            bearTestFVG = array.get(bearFVGArray, i)
            if dispR < showLastFVG
                if na(bearTestFVG.fvgBox)
                    bearTestFVG.fvgBox := box.new(top = bearTestFVG.top, bottom = bearTestFVG.bottom, left = bearTestFVG.left, right = time, xloc = bearTestFVG.xlocFVG, bgcolor = downFVGColor, border_width = 0)
                    bearTestFVG.midLine := line.new(x1 = bearTestFVG.left, y1 = (bearTestFVG.top + bearTestFVG.bottom)/2, x2 = time, y2 = (bearTestFVG.top + bearTestFVG.bottom)/2, xloc = bearTestFVG.xlocFVG, color = color.new(color.white, 75), style = line.style_dashed)
                else
                    bearTestFVG.midLine.set_x2(time + (time - time[1]) * extendFVG)
                    bearTestFVG.fvgBox.set_right(time + (time - time[1]) * extendFVG)
                dispR += 1
            else
                if not na(bearTestFVG.fvgBox)
                    bearTestFVG.fvgBox.delete()
                    bearTestFVG.fvgBox := na
                if not na(bearTestFVG.midLine)
                    bearTestFVG.midLine.delete()
                    bearTestFVG.midLine := na

            if bearBreak > bearTestFVG.top
                if not na(bearTestFVG.fvgBox)
                    bearTestFVG.fvgBox.delete()
                if not na(bearTestFVG.midLine)
                    bearTestFVG.midLine.delete()
                array.remove(bearFVGArray, i)
                totalR := array.size(bearFVGArray)

