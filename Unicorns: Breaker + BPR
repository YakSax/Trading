         left = time[1],
         fvgBox = na,
         midLine = na,
         xlocFVG = xloc.bar_time))

// 3) enforce max retention to reduce memory/box usage
while array.size(bullFVGArray) > maxFVGKeep
    oldBull = array.shift(bullFVGArray)
    if not na(oldBull.fvgBox)
        oldBull.fvgBox.delete()
    if not na(oldBull.midLine)
        oldBull.midLine.delete()

while array.size(bearFVGArray) > maxFVGKeep
