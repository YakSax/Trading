// ========================================
// BALANCED PRICE RANGE
// ========================================


//-----------------------------------------------------------------------------
// Inputs
//-----------------------------------------------------------------------------
show_mitigated = input.bool(true, "Show Mitigated BPR", group="General Configuration")
label_size = input.string("Small", "Label Size", options=["Tiny", "Small", "Normal", "Large"], group="General Configuration")
sensitivity = input.int(5, "Sensitivity", minval=0, maxval=25, group="General Configuration")
show_labels = input.bool(true, "Show Labels", group="General Configuration")

// How many of the most recent BPRs to paint (per side)
display_count = input.int(10, "BPRs to display per side (most recent)", minval=1, maxval=20, group="General Configuration")

// Maximum stored history per side (FIFO)
max_bpr_history = input.int(50, "Maximum Stored BPRs per side (FIFO)", minval=10, maxval=200, group="General Configuration")

// Midpoint Line
show_midpoint = input.bool(true, "Show Midpoint Line", group="Midpoint Line")
midpoint_color = input.color(color.white, "Midpoint Color", group="Midpoint Line")
midpoint_style_str = input.string("Dashed", "Midpoint Style", options=["Solid", "Dashed", "Dotted"], group="Midpoint Line")
midpoint_width = input.int(1, "Midpoint Width", minval=1, group="Midpoint Line")

// Colors
bearish_bpr_color = input.color(color.new(color.red, 70), "Bearish BPR Color", group="Colors")
bullish_bpr_color = input.color(color.new(color.green, 70), "Bullish BPR Color", group="Colors")

// Calculate text size
var text_size = switch label_size
    "Tiny" => size.tiny
    "Small" => size.small
    "Large" => size.large
    => size.normal

var midpoint_style = switch midpoint_style_str
    "Dashed" => line.style_dashed
    "Dotted" => line.style_dotted
    => line.style_solid

//-----------------------------------------------------------------------------
// Arrays: separate histories for bullish and bearish BPRs
//-----------------------------------------------------------------------------
var int[] bull_left_arr     = array.new_int()
var int[] bull_right_arr    = array.new_int()
var float[] bull_top_arr    = array.new_float()
var float[] bull_bottom_arr = array.new_float()
var bool[] bull_mitigated_arr = array.new_bool()
var box[] bull_box_arr      = array.new_box()
var line[] bull_mid_arr     = array.new_line()

var int[] bear_left_arr     = array.new_int()
var int[] bear_right_arr    = array.new_int()
var float[] bear_top_arr    = array.new_float()
var float[] bear_bottom_arr = array.new_float()
var bool[] bear_mitigated_arr = array.new_bool()
var box[] bear_box_arr      = array.new_box()
var line[] bear_mid_arr     = array.new_line()

// Last index for most-recent entries (per side). Scalars modified only in main scope.
var int last_bull_idx = na
var int last_bear_idx = na

//-----------------------------------------------------------------------------
// Helpers: create / delete boxes / midlines for bullish side
//-----------------------------------------------------------------------------
create_bull_box(i) =>
    left   = array.get(bull_left_arr, i)
    right  = array.get(bull_right_arr, i)
    top    = array.get(bull_top_arr, i)
    bottom = array.get(bull_bottom_arr, i)
    col = bullish_bpr_color
    b = box.new(left, top, right, bottom,
         border_color=col, border_width=1, bgcolor=col,
         text= show_labels ? "BPR" : "", text_size=text_size, text_color=color.white,
         text_halign=text.align_right, text_valign=text.align_bottom)
    array.set(bull_box_arr, i, b)
    if show_midpoint
        mid = (top + bottom) / 2
        l = line.new(left, mid, right, mid, color=midpoint_color, width=midpoint_width, style=midpoint_style)
        array.set(bull_mid_arr, i, l)

delete_bull_box(i) =>
    bx = array.get(bull_box_arr, i)
    if not na(bx)
        box.delete(bx)
        array.set(bull_box_arr, i, na)
    ln = array.get(bull_mid_arr, i)
    if not na(ln)
        line.delete(ln)
        array.set(bull_mid_arr, i, na)

// Helpers: create / delete boxes / midlines for bearish side
create_bear_box(i) =>
    left   = array.get(bear_left_arr, i)
    right  = array.get(bear_right_arr, i)
    top    = array.get(bear_top_arr, i)
    bottom = array.get(bear_bottom_arr, i)
    col = bearish_bpr_color
    b = box.new(left, top, right, bottom,
         border_color=col, border_width=1, bgcolor=col,
         text= show_labels ? "BPR" : "", text_size=text_size, text_color=color.white,
         text_halign=text.align_right, text_valign=text.align_bottom)
    array.set(bear_box_arr, i, b)
    if show_midpoint
        mid = (top + bottom) / 2
        l = line.new(left, mid, right, mid, color=midpoint_color, width=midpoint_width, style=midpoint_style)
        array.set(bear_mid_arr, i, l)

delete_bear_box(i) =>
    bx = array.get(bear_box_arr, i)
    if not na(bx)
        box.delete(bx)
        array.set(bear_box_arr, i, na)
    ln = array.get(bear_mid_arr, i)
    if not na(ln)
        line.delete(ln)
        array.set(bear_mid_arr, i, na)

//-----------------------------------------------------------------------------
// Refresh display: create boxes for most recent `display_count` entries per side
// Note: guard against empty arrays by wrapping loops in `if size > 0`
//-----------------------------------------------------------------------------
refresh_display_bull() =>
    total = array.size(bull_left_arr)
    if total > 0
        start_show = math.max(0, total - display_count)
        for i = 0 to total - 1
            bx = array.get(bull_box_arr, i)
            in_range = i >= start_show
            if in_range
                if na(bx)
                    create_bull_box(i)
            else
                if not na(bx)
                    delete_bull_box(i)

refresh_display_bear() =>
    total = array.size(bear_left_arr)
    if total > 0
        start_show = math.max(0, total - display_count)
        for i = 0 to total - 1
            bx = array.get(bear_box_arr, i)
            in_range = i >= start_show
            if in_range
                if na(bx)
                    create_bear_box(i)
            else
                if not na(bx)
                    delete_bear_box(i)

//-----------------------------------------------------------------------------
// Purge oldest entries (FIFO) per side when history exceeds max_bpr_history.
// Each purge function returns number of items purged (as its final expression).
//-----------------------------------------------------------------------------
purge_oldest_bull() =>
    purged = 0
    while array.size(bull_left_arr) > max_bpr_history
        // delete visuals if present
        bx = array.shift(bull_box_arr)
        if not na(bx)
            box.delete(bx)
        ln = array.shift(bull_mid_arr)
        if not na(ln)
            line.delete(ln)
        // shift metadata
        array.shift(bull_left_arr)
        array.shift(bull_right_arr)
        array.shift(bull_top_arr)
        array.shift(bull_bottom_arr)
        array.shift(bull_mitigated_arr)
        purged += 1
    purged  // returned

purge_oldest_bear() =>
    purged = 0
    while array.size(bear_left_arr) > max_bpr_history
        bx = array.shift(bear_box_arr)
        if not na(bx)
            box.delete(bx)
        ln = array.shift(bear_mid_arr)
        if not na(ln)
            line.delete(ln)
        array.shift(bear_left_arr)
        array.shift(bear_right_arr)
        array.shift(bear_top_arr)
        array.shift(bear_bottom_arr)
        array.shift(bear_mitigated_arr)
        purged += 1
    purged

//-----------------------------------------------------------------------------
// Utilities: update right edge of boxes and midlines (per side)
//-----------------------------------------------------------------------------
update_right_bull(i, new_right) =>
    bx = array.get(bull_box_arr, i)
    if not na(bx)
        box.set_right(bx, new_right)
    ln = array.get(bull_mid_arr, i)
    if not na(ln)
        line.set_x2(ln, new_right)
    array.set(bull_right_arr, i, new_right)

update_right_bear(i, new_right) =>
    bx = array.get(bear_box_arr, i)
    if not na(bx)
        box.set_right(bx, new_right)
    ln = array.get(bear_mid_arr, i)
    if not na(ln)
        line.set_x2(ln, new_right)
    array.set(bear_right_arr, i, new_right)

// Mark mitigated (per side)
mark_bull_mitigated(i) =>
    array.set(bull_mitigated_arr, i, true)
    bx = array.get(bull_box_arr, i)
    faded = color.new(bullish_bpr_color, 95)
    if not na(bx)
        if show_mitigated
            box.set_bgcolor(bx, faded)
            box.set_border_color(bx, faded)
        else
            box.delete(bx)
            array.set(bull_box_arr, i, na)
    ln = array.get(bull_mid_arr, i)
    if not na(ln)
        if not show_mitigated
            line.delete(ln)
            array.set(bull_mid_arr, i, na)

mark_bear_mitigated(i) =>
    array.set(bear_mitigated_arr, i, true)
    bx = array.get(bear_box_arr, i)
    faded = color.new(bearish_bpr_color, 95)
    if not na(bx)
        if show_mitigated
            box.set_bgcolor(bx, faded)
            box.set_border_color(bx, faded)
        else
            box.delete(bx)
            array.set(bear_box_arr, i, na)
    ln = array.get(bear_mid_arr, i)
    if not na(ln)
        if not show_mitigated
            line.delete(ln)
            array.set(bear_mid_arr, i, na)

//-----------------------------------------------------------------------------
// Detection logic (kept substantially the same)
//-----------------------------------------------------------------------------
atr_BPR = ta.atr(20)
sens_coeff = sensitivity * 0.05
body_size = math.abs(open - close)
base_cond = (sensitivity == 0 or body_size[1] > (body_size + body_size[2]) * 0.3)
type_cond = true

new_fvg_bearish = base_cond and type_cond and low[2] > high and (low[2] - high) > atr_BPR * sens_coeff
new_fvg_bullish = base_cond and type_cond and low > high[2] and (low - high[2]) > atr_BPR * sens_coeff

// Direction of the most recent ACTIVE BPR:
//  1  = bullish
// -1  = bearish
// na  = none / reset
var int last_bpr_direction = na

// Bullish BPR detection (second FVG is bullish => bullish BPR)
new_bull_bpr = false
bull_mitigated = false  // scalar flag for *this bar*
bull_num_since = ta.barssince(new_fvg_bearish)
if not na(bull_num_since)
    bull_bpr_cond_1 = new_fvg_bullish
    bull_bpr_cond_2 = high[bull_num_since] + low[bull_num_since + 2] + high[2] + low > math.max(low[bull_num_since + 2], low) - math.min(high[bull_num_since], high[2])
    if bull_bpr_cond_1 and bull_bpr_cond_2
        new_bull_bpr := true
        bull_combined_low = math.max(high[bull_num_since], high[2])
        bull_combined_high = math.min(low[bull_num_since + 2], low)
        if bull_combined_high > bull_combined_low
            left_idx = bar_index - bull_num_since - 1
            right_idx = bar_index + 1
            array.push(bull_left_arr, left_idx)
            array.push(bull_right_arr, right_idx)
            array.push(bull_top_arr, bull_combined_high)
            array.push(bull_bottom_arr, bull_combined_low)
            array.push(bull_mitigated_arr, false)
            array.push(bull_box_arr, na)
            array.push(bull_mid_arr, na)
            last_bpr_direction := 1
            // recompute last index (in main scope)
            last_bull_idx := array.size(bull_left_arr) - 1
            // purge oldest if needed and then recompute last index
            purged = purge_oldest_bull()
            if purged > 0
                last_bull_idx := array.size(bull_left_arr) - 1

// Bearish BPR detection (second FVG is bearish => bearish BPR)
new_bear_bpr = false
bear_mitigated = false  // scalar flag for *this bar*
bear_num_since = ta.barssince(new_fvg_bullish)
if not na(bear_num_since)
    bear_bpr_cond_1 = new_fvg_bearish
    bear_bpr_cond_2 = high[bear_num_since] + low[bear_num_since + 2] + high[2] + low > math.max(low[bear_num_since + 2], low) - math.min(high[bear_num_since], high[2])
    if bear_bpr_cond_1 and bear_bpr_cond_2
        new_bear_bpr := true
        bear_combined_low = math.max(high[bear_num_since + 2], high)
        bear_combined_high = math.min(low[bear_num_since], low[2])
        if bear_combined_high > bear_combined_low
            left_idx = bar_index - bear_num_since - 1
            right_idx = bar_index + 1
            array.push(bear_left_arr, left_idx)
            array.push(bear_right_arr, right_idx)
            array.push(bear_top_arr, bear_combined_high)
            array.push(bear_bottom_arr, bear_combined_low)
            array.push(bear_mitigated_arr, false)
            array.push(bear_box_arr, na)
            array.push(bear_mid_arr, na)
            last_bpr_direction := -1
            last_bear_idx := array.size(bear_left_arr) - 1
            purged2 = purge_oldest_bear()
            if purged2 > 0
                last_bear_idx := array.size(bear_left_arr) - 1

// After pushing new items, refresh display for both sides
refresh_display_bull()
refresh_display_bear()

//-----------------------------------------------------------------------------
// Update active boxes (extend right edge) and check mitigation for last entries (per side)
//-----------------------------------------------------------------------------

// Bull side
if not na(last_bull_idx)
    last_ok = last_bull_idx >= 0 and last_bull_idx < array.size(bull_left_arr)
    if last_ok
        invalidate_low = math.min(close, open)
        entry_bottom = array.get(bull_bottom_arr, last_bull_idx)
        if invalidate_low < entry_bottom
            mark_bull_mitigated(last_bull_idx)
            bull_mitigated := true
        if last_bpr_direction == 1
            last_bpr_direction := na
        else
            if not array.get(bull_mitigated_arr, last_bull_idx)
                total = array.size(bull_left_arr)
                start_show = math.max(0, total - display_count)
                if last_bull_idx >= start_show
                    update_right_bull(last_bull_idx, bar_index + 1)

// Bear side
if not na(last_bear_idx)
    last_ok2 = last_bear_idx >= 0 and last_bear_idx < array.size(bear_left_arr)
    if last_ok2
        invalidate_high = math.max(close, open)
        entry_top = array.get(bear_top_arr, last_bear_idx)
        if invalidate_high > entry_top
            mark_bear_mitigated(last_bear_idx)
            bear_mitigated := true
        if last_bpr_direction == -1
            last_bpr_direction := na
        else
            if not array.get(bear_mitigated_arr, last_bear_idx)
                total2 = array.size(bear_left_arr)
                start_show2 = math.max(0, total2 - display_count)
                if last_bear_idx >= start_show2
                    update_right_bear(last_bear_idx, bar_index + 1)

// One more refresh to ensure user changes to display_count are applied
refresh_display_bull()
refresh_display_bear()

//-----------------------------------------------------------------------------
// Alerts
alertcondition(new_bull_bpr, "Bullish BPR Detected", "New Bullish BPR formed")
alertcondition(new_bear_bpr, "Bearish BPR Detected", "New Bearish BPR formed")
alertcondition(bull_mitigated, "Bullish BPR Mitigated", "Bullish BPR has been mitigated")
alertcondition(bear_mitigated, "Bearish BPR Mitigated", "Bearish BPR has been mitigated")
//-----------------------------------------------------------------------------


