// helper to delete the current breaker visuals and remove from history arrays
method deleteBreaker(int leftIdx) =>
    // delete labels stored in BB.aLabels
    while BB.aLabels.size() > 0
        BB.aLabels.pop().delete()

    // delete visual objects if they exist
    if not na(BB.BB_boxA)
        BB.BB_boxA.delete()
    if not na(BB.BB_boxB)
        BB.BB_boxB.delete()
    if not na(BB.BB_line)
        BB.BB_line.delete()
    if not na(BB.PDa_box1)
        BB.PDa_box1.delete()
    if not na(BB.PDa_box2)
        BB.PDa_box2.delete()
    if not na(BB.PDa_boxA)
        BB.PDa_boxA.delete()
    if not na(BB.PDa_boxB)
        BB.PDa_boxB.delete()
    if not na(BB.PDaLine1)
        BB.PDaLine1.delete()
    if not na(BB.PDaLine2)
        BB.PDaLine2.delete()
    if not na(BB.PDaLab_1)
        BB.PDaLab_1.delete()
    if not na(BB.PDaLab_2)
        BB.PDaLab_2.delete()
    if not na(BB.line_1)
        BB.line_1.delete()
    if not na(BB.line_2)
        BB.line_2.delete()
    if not na(BB.TP1_line)
        BB.TP1_line.delete()
    if not na(BB.TP2_line)
        BB.TP2_line.delete()
    if not na(BB.TP3_line)
        BB.TP3_line.delete()
    if not na(BB.HL)
        BB.HL.delete()
    // clear the unicorn tracker for the active breaker
    BB.is_unicorn := false


    // remove matching leftIdx entries from our lightweight history arrays
    i = array.size(aBlockBlIdx) - 1
    while i >= 0
        if aBlockBlIdx.get(i) == leftIdx
            aBlockBlIdx.remove(i)
        i -= 1
    i2 = array.size(aBlockBrIdx) - 1
    while i2 >= 0
        if aBlockBrIdx.get(i2) == leftIdx
            aBlockBrIdx.remove(i2)
        i2 -= 1

    // recreate BB members (assign to fields instead of reassigning BB)
    BB.BB_boxA := box.new(na, na, na, na, border_color=color(na))
    BB.BB_boxB := box.new(na, na, na, na, border_color=color(na)
      , text_size=size.small, text_halign=text.align_right, text_font_family=font.family_monospace)
    BB.BB_line := line.new(na, na, na, na, style=line.style_dashed, color=color.silver)

    BB.PDa_box1 := box.new(na, na, na, na, border_color=color(na))
    BB.PDaLine1 := line.new(na, na, na, na, color=PDSCss)
    BB.PDaLab_1 := label.new(na, na, color=color(na))

    BB.PDa_box2 := box.new(na, na, na, na, border_color=color(na))
    BB.PDaLine2 := line.new(na, na, na, na, color=PDSCss)
    BB.PDaLab_2 := label.new(na, na, color=color(na))

    BB.line_1 := line.new(na, na, na, na, color=PDSCss)
    BB.line_2 := line.new(na, na, na, na, color=PDSCss)

    BB.TP1_line := line.new(na, na, na, na, color=tpCss)
    BB.TP2_line := line.new(na, na, na, na, color=tpCss)
    BB.TP3_line := line.new(na, na, na, na, color=tpCss)

    BB.HL := label.new(na, na, color=color(na), textcolor=PDtxtCss, yloc=yloc.price)

    // recreate the labels array
    BB.aLabels := array.new<label>(1, label(na))

    // reset flags/fields
    BB.Broken    := false
    BB.Mitigated := false
    BB.Broken_1  := false
    BB.Broken_2  := false
    BB.PDbroken1 := false
    BB.PDbroken2 := false
    BB.TP1_hit   := false
    BB.TP2_hit   := false
    BB.TP3_hit   := false
    BB.scalp     := false
